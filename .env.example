# Firebase configuration — copy this file to .env and fill in your values.
# Get these from the Firebase Console: https://console.firebase.google.com/
# Run: flutterfire configure   to regenerate these for your own Firebase project.
#
# Usage:
#   flutter run  --dart-define-from-file=.env
#   flutter build apk --dart-define-from-file=.env

# ── Shared ────────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# ── Web / Linux / Windows (shared API key) ────────────────────────────────────
FIREBASE_WEB_API_KEY=your-web-api-key
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com

# ── Web ───────────────────────────────────────────────────────────────────────
FIREBASE_WEB_APP_ID=1:your-project-number:web:your-web-app-id
FIREBASE_MEASUREMENT_ID_WEB=G-XXXXXXXXXX

# ── Android ───────────────────────────────────────────────────────────────────
FIREBASE_ANDROID_API_KEY=your-android-api-key
FIREBASE_ANDROID_APP_ID=1:your-project-number:android:your-android-app-id

# ── iOS / macOS (shared) ──────────────────────────────────────────────────────
FIREBASE_IOS_API_KEY=your-ios-api-key
FIREBASE_IOS_APP_ID=1:your-project-number:ios:your-ios-app-id
FIREBASE_IOS_BUNDLE_ID=com.yourcompany.yourapp

# ── Windows ───────────────────────────────────────────────────────────────────
FIREBASE_WINDOWS_APP_ID=1:your-project-number:web:your-windows-app-id
FIREBASE_MEASUREMENT_ID_WINDOWS=G-XXXXXXXXXX
